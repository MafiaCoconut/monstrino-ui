# Backend API Configuration
# Example: http://localhost:8000 or https://api.monstrino.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Site URL for canonical/robots/sitemap
# Example: https://monstrino.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Feature Flags
NEXT_PUBLIC_LOGIN_DISABLED=false
NEXT_PUBLIC_REGISTRATION_DISABLED=false

# Revalidation Secret (server-side)
REVALIDATE_SECRET=change-me

# Analytics website id (Umami-style script)
# Test: 1b2d07f4-64e2-4f9d-85b5-1eda70cc3677
# Production: 6f893769-aded-4197-8a6f-8f400c764dc8
NEXT_PUBLIC_ANALYTICS_WEBSITE_ID=
